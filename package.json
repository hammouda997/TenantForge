{
  "name": "tenantforge",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @tenantforge/api db:generate",
    "db:migrate": "pnpm --filter @tenantforge/api db:migrate",
    "db:seed": "pnpm --filter @tenantforge/api db:seed",
    "db:studio": "pnpm --filter @tenantforge/api db:studio"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
